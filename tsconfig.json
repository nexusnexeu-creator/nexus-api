{
  "compilerOptions": {
    "target":                           "ES2020",
    "module":                           "commonjs",
    "lib":                              ["ES2020"],
    "types":                            ["node"],
    "outDir":                           "./dist",
    "rootDir":                          "./src",
    "strict":                           true,
    "esModuleInterop":                  true,
    "skipLibCheck":                     true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":                true,
    "noImplicitAny":                    true,
    "noUnusedLocals":                   true,
    "noUnusedParameters":               true,
    "noImplicitReturns":                true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}